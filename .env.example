KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

POLL_INTERVAL_SECONDS=5
POLL_JITTER_PCT=0.15

ORDERBOOK_REFRESH_SECONDS=15

MAX_MARKETS=400

MIN_LIQUIDITY_CENTS=2000
MAX_SPREAD_CENTS=15
MIN_VOLUME_24H=0

MIN_FILL_QTY=25

STALE_LAST_AGE_SECONDS=60

RECENCY_WEIGHTS=0.50,0.35,0.15

BANKROLL=1000
KELLY_FRACTION=0.25
MAX_BET_PCT=0.05

ARB_BANKROLL_SHARE=0.60
FAIRVALUE_BANKROLL_SHARE=0.30

MIN_EDGE_PCT=0.5
MIN_NET_EDGE_PCT=1.0

ASSUME_TAKER_FEES=true

DEMO_MODE=false

HOST=0.0.0.0
PORT=8000

USE_NATIVE_WS=false
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

EXECUTION_MODE=off
MAX_DAILY_LOSS=50
KILL_SWITCH=false
KILL_SWITCH_FILE=/tmp/kalshi-kill-switch
PAPER_SLIPPAGE_CENTS=1.0
PAPER_STATE_PATH=./paper_state.json
POSITION_STATE_PATH=./positions.json

ALERT_MIN_EDGE_PCT=5.0
ALERT_COOLDOWN_SECONDS=300
TELEGRAM_BOT_TOKEN=
